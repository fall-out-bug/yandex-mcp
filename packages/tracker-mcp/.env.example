# --- Required (single-user / stdio mode) ---
# OAuth token for ONE user (single-user / stdio mode).
# In org/multi-user (HTTP) mode credentials come per request or via OAuth, and
# these are ignored.
TRACKER_TOKEN=
# Organisation ID (Tracker administration -> Organisations). Always required
# (defines the org scope for every Tracker call).
TRACKER_ORG_ID=

# --- Optional ---
# X-Org-ID (Yandex 360, default) or X-Cloud-Org-ID (Yandex Cloud).
# TRACKER_ORG_HEADER=X-Org-ID
# TRACKER_BASE_URL=https://api.tracker.yandex.net/v3
# TRACKER_AUTH_SCHEME=OAuth   # or Bearer (IAM)
# Transport: stdio (default) | http
# MCP_TRANSPORT=stdio
# MCP_HTTP_PORT=3009

# =============================================================================
# Standalone OAuth profile (HTTP transport only)
# =============================================================================
# Set all three to ENABLE the standalone "connect -> authorize -> use" profile:
# the server runs its OWN MCP authorization server, each connecting user
# authorizes via Yandex, and their Yandex token is kept SERVER-SIDE (never sent
# to the MCP client). See README "Standalone OAuth profile".
#
# When these are UNSET, HTTP mode falls back to the v0.1 per-request-bearer
# profile (each request carries Authorization + X-Org-ID headers).
#
# TRACKER_OAUTH_CLIENT_ID=      # your Yandex OAuth app client_id
# TRACKER_OAUTH_CLIENT_SECRET=  # your Yandex OAuth app client_secret
# TRACKER_OAUTH_PUBLIC_URL=     # public HTTPS base URL of THIS server
#                                # (Yandex redirects back to ${PUBLIC_URL}/auth/yandex/callback)
#
# The Yandex OAuth app must register the redirect URI:
#   ${TRACKER_OAUTH_PUBLIC_URL}/auth/yandex/callback
# Scopes requested: cloud:auth tracker:read tracker:write
