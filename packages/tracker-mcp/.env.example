# --- Required ---
# OAuth token for ONE user (single-user / stdio mode).
# In org/multi-user mode (HTTP transport), credentials are passed per request
# and these are ignored.
TRACKER_TOKEN=
# Organisation ID (Tracker administration -> Organisations).
TRACKER_ORG_ID=

# --- Optional ---
# X-Org-ID (Yandex 360, default) or X-Cloud-Org-ID (Yandex Cloud).
# TRACKER_ORG_HEADER=X-Org-ID
# TRACKER_BASE_URL=https://api.tracker.yandex.net/v3
# TRACKER_AUTH_SCHEME=OAuth   # or Bearer (IAM)
# Transport: stdio (default) | http
# MCP_TRANSPORT=stdio
# MCP_HTTP_PORT=3009
